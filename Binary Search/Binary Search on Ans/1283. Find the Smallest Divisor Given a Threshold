class Solution {
public:
    int smallestDivisor(vector<int>& nums, int threshold) {
        int s = 1;
        int maxi = *max_element(nums.begin(), nums.end());
        int e = maxi;
        int ans;

        int mid = s + (e - s) / 2;

        while (s <= e) {
            long long sum = 0;

            if (mid != 0) {
                for (auto i : nums) {
                    sum += (i + mid - 1LL) / mid;
                }
            }

            if (sum <= threshold) {
                ans = mid;
                e = mid - 1;
            } else {
                s = mid + 1;
            }
            mid = s + (e - s) / 2;
        }
        return ans;
    }
};
